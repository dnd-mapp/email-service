{
  "name": "@dnd-mapp/email-service",
  "version": "0.0.0",
  "description": "",
  "author": "NoNamer777",
  "private": true,
  "license": "MIT",
  "scripts": {
    "gen:ssl-certs": "mkcert -cert-file ssl-cert.pem -key-file ssl-key.pem localhost.email.dndmapp.dev localhost 127.0.0.1",
    "gen:prisma": "pnpm exec prisma generate",
    "start": "pnpm exec nest start -w",
    "build": "pnpm exec nest build",
    "prisma:migrate-dev": "pnpm exec prisma migrate dev",
    "prisma:migrate-deploy": "pnpm exec prisma migrate deploy",
    "prisma:seed": "pnpm exec prisma db seed",
    "docker:build": "docker build -f .docker/Dockerfile -t dndmapp/email-service:latest .",
    "docker:bake": "docker buildx bake -f .docker/bake.hcl app",
    "docker:compose:up": "docker compose -f .docker/compose.yaml up -d",
    "docker:compose:down": "docker compose -f .docker/compose.yaml down",
    "test": "pnpm exec vitest run",
    "test:development": "pnpm exec vitest --ui --watch",
    "lint": "pnpm lint:eslint && pnpm lint:markdownlint",
    "lint:eslint": "pnpm exec eslint \"{src,test}/**/*\" --cache",
    "lint:markdownlint": "pnpm exec markdownlint \"**/*.md\"",
    "format:check": "pnpm exec prettier -l .",
    "format:write": "pnpm exec prettier -w ."
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=10.33.0"
  },
  "dependencies": {
    "@dnd-mapp/shared-utils": "~1.2",
    "@dotenvx/dotenvx": "~1.57",
    "@fastify/helmet": "~13.0",
    "@fastify/static": "~9.0",
    "@nestjs/common": "~11.1",
    "@nestjs/config": "~4.0.3",
    "@nestjs/core": "~11.1",
    "@nestjs/platform-fastify": "~11.1",
    "@nestjs/swagger": "~11.2",
    "@nestjs/terminus": "~11.1",
    "@nestjs/throttler": "~6.5",
    "@prisma/adapter-mariadb": "~7.5",
    "@prisma/client": "~7.5",
    "class-transformer": "~0.5",
    "class-validator": "~0.14",
    "fastify": "~5.8",
    "mariadb": "~3.5",
    "nanoid": "~5.1",
    "prisma": "~7.5",
    "reflect-metadata": "~0.2",
    "rxjs": "~7.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "~3.3",
    "@eslint/js": "~10.0",
    "@nestjs/cli": "~11.0",
    "@nestjs/schematics": "~11.0",
    "@nestjs/testing": "~11.1",
    "@types/node": "~24.12",
    "@vitest/coverage-v8": "~4.1",
    "@vitest/ui": "~4.1",
    "eslint": "~10.1",
    "eslint-config-prettier": "~10.1",
    "generate-package-json-webpack-plugin": "~2.7",
    "globals": "~17.4",
    "markdownlint": "~0.40",
    "markdownlint-cli": "~0.48",
    "prettier": "~3.8",
    "prettier-plugin-organize-imports": "~4.3",
    "ts-loader": "~9.5",
    "ts-node": "~10.9",
    "tsconfig-paths": "~4.2",
    "tsconfig-paths-webpack-plugin": "~4.2",
    "typescript": "~5.9",
    "typescript-eslint": "~8.57",
    "vite": "~8.0",
    "vitest": "~4.1",
    "webpack": "~5.105",
    "webpack-node-externals": "~3.0"
  }
}
