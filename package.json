{
  "name": "@dnd-mapp/email-service",
  "version": "0.0.0",
  "description": "",
  "author": "NoNamer777",
  "private": true,
  "license": "MIT",
  "scripts": {
    "gen:ssl-certs": "mkcert -cert-file ssl-cert.pem -key-file ssl-key.pem localhost.email.dndmapp.dev localhost 127.0.0.1",
    "gen:prisma": "pnpm exec prisma generate",
    "start": "pnpm exec nest start -w",
    "build": "pnpm exec nest build",
    "prisma:migrate-dev": "pnpm exec prisma migrate dev",
    "prisma:migrate-deploy": "pnpm exec prisma migrate deploy",
    "prisma:seed": "pnpm exec prisma db seed",
    "docker:build": "docker build -f .docker/Dockerfile -t dndmapp/email-service:latest .",
    "docker:bake": "docker buildx bake -f .docker/bake.hcl app",
    "test": "pnpm exec vitest run",
    "test:development": "pnpm exec vitest --ui --watch",
    "lint": "pnpm lint:eslint && pnpm lint:markdownlint",
    "lint:eslint": "pnpm exec eslint \"{src,test}/**/*\" --cache",
    "lint:markdownlint": "pnpm exec markdownlint \"**/*.md\"",
    "format:check": "pnpm exec prettier -l .",
    "format:write": "pnpm exec prettier -w ."
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.app.json --require tsconfig-paths/register prisma/seed.ts"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "~24.14"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "~24.14",
      "onFail": "error"
    },
    "packageManager": [
      {
        "name": "pnpm",
        "version": "10.33.0",
        "onFail": "error"
      },
      {
        "name": "npm",
        "version": "11.11.0",
        "onFail": "warn"
      }
    ]
  },
  "dependencies": {
    "@dnd-mapp/shared-utils": "~1.2.0",
    "@dotenvx/dotenvx": "~1.61.0",
    "@fastify/helmet": "~13.0.2",
    "@fastify/static": "~9.1.1",
    "@nestjs/common": "~11.1.19",
    "@nestjs/config": "~4.0.4",
    "@nestjs/core": "~11.1.19",
    "@nestjs/platform-fastify": "~11.1.19",
    "@nestjs/swagger": "~11.3.0",
    "@nestjs/terminus": "~11.1.1",
    "@nestjs/throttler": "~6.5.0",
    "@prisma/adapter-mariadb": "~7.7.0",
    "@prisma/client": "~7.7.0",
    "class-transformer": "~0.5.1",
    "class-validator": "~0.15.1",
    "fastify": "~5.8.4",
    "handlebars": "~4.7.9",
    "mariadb": "~3.5.2",
    "nanoid": "~5.1.9",
    "prisma": "~7.7.0",
    "reflect-metadata": "~0.2.2",
    "resend": "~6.12.0",
    "rxjs": "~7.8.2",
    "tsx": "~4.21.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "~3.3.5",
    "@eslint/js": "~10.0.1",
    "@nestjs/cli": "~11.0.21",
    "@nestjs/schematics": "~11.1.0",
    "@nestjs/testing": "~11.1.19",
    "@types/node": "~24.12.2",
    "@vitest/coverage-v8": "~4.1.4",
    "@vitest/ui": "~4.1.4",
    "eslint": "~10.2.0",
    "eslint-config-prettier": "~10.1.8",
    "generate-package-json-webpack-plugin": "~2.7.0",
    "globals": "~17.5.0",
    "markdownlint": "~0.40.0",
    "markdownlint-cli": "~0.48.0",
    "prettier": "~3.8.3",
    "prettier-plugin-organize-imports": "~4.3.0",
    "ts-loader": "~9.5.7",
    "ts-node": "~10.9.2",
    "tsconfig-paths": "~4.2.0",
    "tsconfig-paths-webpack-plugin": "~4.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "~8.58.2",
    "vite": "~8.0.8",
    "vitest": "~4.1.4",
    "webpack": "~5.106.2",
    "webpack-node-externals": "~3.0.0"
  }
}
