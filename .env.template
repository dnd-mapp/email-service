# Server Configuration
# The host address the server will bind to (Default: 0.0.0.0)
EMAIL_SERVICE_HOST="0.0.0.0"

# The port number the server will listen on (Range: 1024-65535, Default: 4350)
EMAIL_SERVICE_PORT="4450"

# CORS Configuration
# Comma-separated list of allowed origins
EMAIL_SERVICE_CORS_ORIGINS="https://localhost.auth.dndmapp.dev:4350"

# SSL Configuration
# Required for local development environments
EMAIL_SERVICE_SSL_CERT_PATH="ssl-cert.pem"
EMAIL_SERVICE_SSL_KEY_PATH="ssl-key.pem"

# Database Configuration
EMAIL_SERVICE_DB_HOST="localhost"
EMAIL_SERVICE_DB_PORT="3306"
EMAIL_SERVICE_DB_USER="admin"
EMAIL_SERVICE_DB_PASSWORD="password123"
EMAIL_SERVICE_DB_SCHEMA="email_db"

PRISMA_DB_USER="prisma"
PRISMA_DB_PASSWORD="prisma-password"

# Resend Configuration
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM="noreply@yourdomain.com"

# Connection String (Interpolated)
EMAIL_SERVICE_DB_URL="mysql://${PRISMA_DB_USER}:${PRISMA_DB_PASSWORD}@${EMAIL_SERVICE_DB_HOST}:${EMAIL_SERVICE_DB_PORT}/${EMAIL_SERVICE_DB_SCHEMA}"
