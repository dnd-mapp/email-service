{
    "references": [{ "path": "./tsconfig.app.json" }, { "path": "./tsconfig.spec.json" }],
    "include": [],
    "files": [],
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "baseUrl": "./",
        "emitDecoratorMetadata": true,
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "forceConsistentCasingInFileNames": true,
        "isolatedModules": true,
        "module": "NodeNext",
        "moduleResolution": "nodenext",
        "newLine": "lf",
        "noFallthroughCasesInSwitch": true,
        "noImplicitAny": true,
        "noImplicitOverride": true,
        "noImplicitReturns": true,
        "noImplicitThis": true,
        "noPropertyAccessFromIndexSignature": true,
        "noUncheckedIndexedAccess": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "outDir": "./dist/email-service",
        "paths": {
            "@/app": ["src/app/index.ts"],
            "@/common": ["src/common/index.ts"],
            "@/email": ["src/email/index.ts"],
            "@/email/domain": ["src/email/domain/index.ts"],
            "@/email/test": ["src/email/test/index.ts"],
            "@/email-template": ["src/email-template/index.ts"],
            "@/email-template/domain": ["src/email-template/domain/index.ts"],
            "@/email-template/test": ["src/email-template/test/index.ts"],
            "@/email-template-variable": ["src/email-template-variable/index.ts"],
            "@/email-template-variable/domain": ["src/email-template-variable/domain/index.ts"],
            "@/email-template-variable/test": ["src/email-template-variable/test/index.ts"],
            "@/prisma/*": ["./prisma/client/*"],
            "@/sender-email": ["src/sender-email/index.ts"],
            "@/sender-email/domain": ["src/sender-email/domain/index.ts"],
            "@/sender-email/test": ["src/sender-email/test/index.ts"],
            "@/shared-utils": ["src/shared/utils/index.ts"],
            "@/test": ["test/index.ts"]
        },
        "skipDefaultLibCheck": true,
        "skipLibCheck": true,
        "strictBindCallApply": true,
        "strictBuiltinIteratorReturn": true,
        "strictFunctionTypes": true,
        "strictNullChecks": true,
        "strictPropertyInitialization": true,
        "target": "ES2024",
        "useUnknownInCatchVariables": true
    }
}
